# ============================================
# FangOps Configuration
# Copy this file to .env and fill in the values
# ============================================

# ---- Server ----
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
DASHBOARD_PORT=5173

# ---- Database ----
# SQLite for local dev (default), PostgreSQL for production
DATABASE_URL=file:./fangops.db
# DATABASE_URL=postgresql://user:password@localhost:5432/fangops

# ---- Auth ----
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY=7d

# ---- LLM Providers (configure at least one) ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ---- Local LLM (Ollama) ----
OLLAMA_BASE_URL=http://localhost:11434

# ---- LLM Budget ----
LLM_DAILY_BUDGET_USD=5.00
LLM_MONTHLY_BUDGET_USD=100.00
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini

# ---- Monitoring Integrations ----
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001

# ---- Notification Channels ----
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=fangops@yourdomain.com

# ---- Remediation Safety ----
# Options: OBSERVE | SAFE | APPROVAL | AUTONOMOUS
REMEDIATION_DEFAULT_TIER=OBSERVE

# ---- OpenFang Integration (optional) ----
OPENFANG_BINARY_PATH=
OPENFANG_API_URL=http://localhost:4200
