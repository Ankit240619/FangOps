{
    "name": "@fangops/core",
    "version": "0.1.0",
    "description": "FangOps core library — shared types, config, events, abstraction layer",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./types": {
            "import": "./dist/types/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./config": {
            "import": "./dist/config/index.js",
            "types": "./dist/config/index.d.ts"
        },
        "./events": {
            "import": "./dist/events/index.js",
            "types": "./dist/events/index.d.ts"
        },
        "./logger": {
            "import": "./dist/logger/index.js",
            "types": "./dist/logger/index.d.ts"
        }
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist"
    },
    "dependencies": {
        "cron": "^3.1.0",
        "nanoid": "^5.0.0",
        "pino": "^9.0.0",
        "pino-pretty": "^11.0.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/node": "^20.14.0",
        "@types/uuid": "^11.0.0",
        "eslint": "^9.0.0",
        "rimraf": "^6.0.0",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0",
        "uuid": "^13.0.0",
        "vitest": "^2.0.0"
    }
}