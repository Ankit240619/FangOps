{
    "name": "@fangops/api",
    "version": "0.1.0",
    "description": "FangOps REST API server",
    "type": "module",
    "main": "./dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "test": "vitest run",
        "lint": "eslint src/",
        "typecheck": "tsc --noEmit",
        "clean": "rimraf dist",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "tsx ../../scripts/seed-data.ts"
    },
    "dependencies": {
        "@fangops/core": "workspace:*",
        "@fastify/cors": "^10.0.0",
        "@fastify/jwt": "^9.0.0",
        "@fastify/rate-limit": "^10.0.0",
        "@libsql/client": "^0.17.0",
        "@types/uuid": "^11.0.0",
        "bcrypt": "^5.1.0",
        "drizzle-orm": "^0.45.1",
        "fastify": "^5.0.0",
        "fastify-plugin": "^5.1.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@types/bcrypt": "^5.0.0",
        "@types/node": "^20.14.0",
        "drizzle-kit": "^0.31.9",
        "eslint": "^9.0.0",
        "rimraf": "^6.0.0",
        "tsx": "^4.16.0",
        "typescript": "^5.5.0",
        "vitest": "^2.0.0"
    }
}